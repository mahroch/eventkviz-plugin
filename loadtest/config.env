# EventKviz load test — konfigurácia (commitnuté, žiadne tajomstvá; len URL/slugy).
# Uprav podľa eventu, proti ktorému testuješ. Odporúčané: dedikovaný event „loadtest".

BASE_URL=https://eventkviz.sk

# Event slug proti ktorému testovať. POUŽI DEDIKOVANÝ TEST EVENT (nie reálny!),
# lebo načítanie stránok kvízu vytvorí v DB question_set záznamy pre lt-userov.
AKCIA=loadtest

# Mapový sub-kvíz slug (z event_mapa_quizzes daného eventu). Prázdne = mapa sa preskočí.
MQ=

# Ktoré typy testovať (čiarkou). hub = vstupná stránka.
TYPES=hub,music,movies,knowledge,sudoku,mapa

# Sťahovať aj ťažké assety (audio/video/geojson)? true = realistický prenos.
FETCH_ASSETS=true

# Reprezentatívny geojson pre mapový asset test (mapa-form ho fetchuje z tohto adresára).
MAP_GEOJSON=https://eventkviz.sk/wp-content/plugins/eventkviz/public/data/regions/world-mountains.geojson

# Default počet virtuálnych hráčov (prepíšeš 2. argumentom run.sh).
VUS=50
