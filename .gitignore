.DS_Store
.vscode/
*.log
node_modules/
vendor/
# Výnimka: public/vendor/ obsahuje vendored frontend assets (Leaflet.draw, …),
# tie musia byť v repo aby plugin fungoval bez external CDN deps.
!public/vendor/
!public/vendor/**

# Deploy credentials — NIKDY do repo
deploy/.env
deploy/backups/*.sql
deploy/backups/*.sql.gz
deploy/backups/*.tar.gz

# Theme-only deploy rollback snapshoty (deploy-theme-only.sh) — lokálne, per-deploy, netreba v repo
deploy/backups/prod-theme-*/

# Generované PDF z MD (lokálne pre Maroša, regenerable cez scripts/generate-pdf.sh)
*-v*.pdf