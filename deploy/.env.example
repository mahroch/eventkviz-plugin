# Eventkviz deploy credentials — skopíruj na .env a vyplň reálnymi hodnotami.
# .env je v .gitignore — NIKDY nesmie ísť do repo.
#
# Kde získaš credentials:
# - SSH: Websupport admin → Pokročilá konfigurácia → Konzola → Základná shell konzola
#   → Aktivovať. Po aktivácii sa zobrazia host/port/user/heslo.
# - MySQL: Websupport admin → Pokročilá konfigurácia → Databázy → Detail eventkviz_db
# - WP path: po prvom SSH login si overím cez `discovery.sh` (zvyčajne ~/web/...)

# ============== LOKÁLNE (MAMP) ==============
LOCAL_DB_HOST=localhost:8889
LOCAL_DB_NAME=eventkviz
LOCAL_DB_USER=root
LOCAL_DB_PASS=root
LOCAL_WP_PATH=/Applications/MAMP/htdocs/eventkviz
LOCAL_URL=http://localhost:8888/eventkviz

# ============== WEBSUPPORT PROD ==============
# SSH (po aktivácii shell konzoly v Websupport admin)
PROD_SSH_HOST=                  # napr. eventkviz.sk alebo s1.websupport.sk
PROD_SSH_PORT=22                # Websupport často iný (22013, 23456...), pozri po aktivácii
PROD_SSH_USER=                  # zvyčajne rovnaký ako FTP user (eventkviz.sk)
PROD_SSH_PASS=                  # ak nie SSH key

# MySQL (z Websupport admin → Databázy)
PROD_DB_HOST=                   # mariadbXX.websupport.sk
PROD_DB_NAME=                   # eventkviz_xxx
PROD_DB_USER=
PROD_DB_PASS=

# WordPress paths (po SSH login si overím sám)
PROD_WP_PATH=                   # napr. /data/web/virtuals/.../web alebo ~/web
PROD_PLUGIN_PATH=               # = ${PROD_WP_PATH}/wp-content/plugins/eventkviz
PROD_URL=https://eventkviz.sk

# Optional: SSH key path (preferred over password)
# PROD_SSH_KEY=~/.ssh/eventkviz_websupport
